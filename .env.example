# MongoDB Atlas connection string
# Get this from MongoDB Atlas after creating a free cluster
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/calldesk?retryWrites=true&w=majority

# Server port (Railway will auto-assign, local development uses 3000)
PORT=3000

# JWT Secret for authentication (use a strong random string in production)
JWT_SECRET=your-super-secret-jwt-key-change-in-production
